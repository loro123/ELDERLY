<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Admin header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/bg_strip"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/admin_mode_title"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/btnAdminClose"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/close"
            style="@style/Widget.ElderlyRemote.Button.Small" />

    </LinearLayout>

    <!-- Tab row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/tabRow"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <Button
                android:id="@+id/tabPairing"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/tab_pairing"
                style="@style/Widget.ElderlyRemote.Tab" />

            <Button
                android:id="@+id/tabFavorites"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/tab_favorites"
                style="@style/Widget.ElderlyRemote.Tab" />

            <Button
                android:id="@+id/tabControls"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/tab_controls"
                style="@style/Widget.ElderlyRemote.Tab" />

            <Button
                android:id="@+id/tabImportExport"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/tab_import_export"
                style="@style/Widget.ElderlyRemote.Tab" />

            <Button
                android:id="@+id/tabTestPad"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/tab_test_pad"
                style="@style/Widget.ElderlyRemote.Tab" />

            <Button
                android:id="@+id/tabPin"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/tab_pin"
                style="@style/Widget.ElderlyRemote.Tab" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Panel container — only one panel visible at a time -->
    <FrameLayout
        android:id="@+id/panelContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
